# =============================================================================
# Auto-Mihomo 环境配置
# 复制此文件为 .env 并填写实际值:  cp .env.example .env
# =============================================================================

# Clash 订阅 URL (必填, 支持 Clash/ClashMeta YAML 格式)
MIHOMO_SUB_URL=https://example.com/api/v1/client/subscribe?token=YOUR_TOKEN

# Mihomo 二进制路径
MIHOMO_BIN=/opt/mihomo/mihomo

# Mihomo 工作目录 (存放 geoip.dat 等数据文件)
MIHOMO_HOME=/opt/mihomo

# 混合代理端口 (HTTP + SOCKS5)
MIHOMO_MIXED_PORT=7893

# Mihomo RESTful API 端口
MIHOMO_API_PORT=9090

# Mihomo controller 监听地址 (默认仅本机访问, 推荐)
MIHOMO_CONTROLLER_HOST=127.0.0.1

# Mihomo RESTful API 鉴权密钥 (强烈建议设置随机长字符串)
# 可用: bash scripts/generate_secrets.sh --write-env
MIHOMO_API_SECRET=CHANGE_ME_MIHOMO_SECRET

# 节点测试并发数
MIHOMO_TEST_WORKERS=50

# TCP 连接测试超时 (秒)
MIHOMO_TCP_TIMEOUT=3

# 代理模式:
# - process-proxy: 仅为 OpenClaw/进程注入代理环境变量 (默认, 推荐)
# - gateway-proxy: 预留给透明代理/网关场景 (当前仓库未完整实现)
AUTO_MIHOMO_PROXY_MODE=process-proxy

# 实际 HTTP 探测选节点使用的 URL (用于替代纯 TCP connect 选优)
MIHOMO_HTTP_PROBE_URL=http://www.gstatic.com/generate_204
MIHOMO_HTTP_PROBE_TIMEOUT=12

# MCP HTTP 服务端口
MCP_SERVER_PORT=8900

# MCP HTTP 服务监听地址 (默认仅本机访问, 推荐配合 OpenClaw 本机调用)
MCP_SERVER_HOST=127.0.0.1

# MCP API 鉴权 Token (Bearer). 留空=不鉴权; 建议设置
MCP_API_TOKEN=CHANGE_ME_MCP_TOKEN
